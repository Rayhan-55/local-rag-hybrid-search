# ---- OCR ----
OCR_ENGINE=tesseract        # tesseract | surya
OCR_LANGUAGES=ben+eng
PDF_RENDER_DPI=300

# ---- Embeddings ----
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu         # cpu | cuda

# ---- Chunking ----
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# ---- Vector store ----
COLLECTION_NAME=documents

# ---- LLM (Ollama, local) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
LLM_TIMEOUT_SECONDS=120

# ---- Retrieval ----
TOP_K=5
